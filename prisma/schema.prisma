generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PROCUREMENT
  WAREHOUSE
  SALES
  ACCOUNTS
  VIEWER
  OPERATIONS
  CUSTOMER_MANAGER
}

enum LCType {
  SIGHT
  USANCE
  TT
  LOCAL
}

enum SalesOrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAYMENT_CONFIRMED
  DO_ISSUED
  DELIVERED
  INVOICED
  CANCELLED
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  TRANSFER
  ADJUSTMENT
  RESERVATION
  RELEASE
}

enum PaymentTerms {
  FULL_PAYMENT
  DEPOSIT_BALANCE
  CREDIT
}

enum CustomerType {
  DISTRIBUTOR
  INSTALLER
  DIRECT
}

enum ExpenseCategory {
  SALARY
  COMMISSION
  WAREHOUSE_RENT
  UTILITIES
  TRANSPORT
  MARKETING
  OFFICE
  OTHER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(VIEWER) // legacy categorisation — retained for back-compat; access now derives from roleRef + permissions
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Granular access control
  roleId      String?
  roleRef     Role?            @relation(fields: [roleId], references: [id])
  fullAccess  Boolean          @default(false) // unrestricted "admin" access; ignores per-module permissions
  permissions UserPermission[] // per-user overrides on top of the assigned role's defaults

  salesOrders      SalesOrder[]
  auditLogs        AuditLog[]
  stockAdjustments StockMovement[]
  deliveryOrders   DeliveryOrder[]
  expenses         Expense[]
  customerReceipts CustomerReceipt[]
  salesReturns     SalesReturn[]
  openingBalances  OpeningBalance[]
}

// A named, admin-managed role title that carries a set of default module permissions.
model Role {
  id          String           @id @default(cuid())
  title       String           @unique
  description String?
  fullAccess  Boolean          @default(false) // grants unrestricted access regardless of permission rows
  isSystem    Boolean          @default(false) // protects built-in roles (e.g. Admin) from deletion
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       User[]
}

// Default permission for a module, attached to a Role.
model RolePermission {
  id       String  @id @default(cuid())
  roleId   String
  role     Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module   String
  canRead  Boolean @default(false)
  canWrite Boolean @default(false)

  @@unique([roleId, module])
}

// Per-user override of a module permission. A row's presence means it overrides the role default;
// absence means the module inherits the role's default.
model UserPermission {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  module   String
  canRead  Boolean @default(false)
  canWrite Boolean @default(false)

  @@unique([userId, module])
}

model ExchangeRate {
  id        String   @id @default(cuid())
  date      DateTime
  source    String
  rate      Float
  notes     String?
  createdAt DateTime @default(now())

  costings       CostingCalculation[]
  purchaseOrders PurchaseOrder[]
}

model TaxConfig {
  id              String   @id @default(cuid())
  name            String
  customsDuty     Float    @default(3)
  additionalCD    Float    @default(0)
  excise          Float    @default(0)
  salesTax        Float    @default(18)
  additionalST    Float    @default(0)
  incomeTax       Float    @default(1.5)
  handlingPerWatt Float    @default(2.0)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  costings CostingCalculation[]
}

model Product {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  category          String   @default("Solar Panel")
  wattage           Int
  brand             String
  skuName           String?
  panelsPerContainer Int?
  palletsPerContainer Int?
  lowStockThreshold Int      @default(100)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  defaultSupplierId String?
  defaultSupplier   Supplier? @relation("ProductDefaultSupplier", fields: [defaultSupplierId], references: [id])

  purchaseOrders    PurchaseOrder[]
  stockEntries      StockEntry[]
  salesOrderLines   SalesOrderLine[]
  quotationLines    QuotationLine[]
  deliveryOrderLines DeliveryOrderLine[]
  salesReturnLines  SalesReturnLine[]
}

model Supplier {
  id              String   @id @default(cuid())
  name            String
  address         String?
  country         String?
  contactPerson   String?
  contactEmail    String?
  contactPhone    String?
  bankDetails     String?
  defaultLeadTime Int?
  paymentTerms    String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrders   PurchaseOrder[]
  defaultForProducts Product[] @relation("ProductDefaultSupplier")
}

model Customer {
  id            String       @id @default(cuid())
  name          String
  type          CustomerType @default(DIRECT)
  ntn           String?
  strn          String?
  address       String?
  contactPerson String?
  contactPhone  String?
  contactEmail  String?
  creditLimit   Float?
  paymentTerms  PaymentTerms @default(FULL_PAYMENT)
  active        Boolean      @default(true)
  // Set when a party with transaction history is "deleted": the row + its past
  // records stay for reference, but it's hidden from lists and dropdowns.
  archivedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  salesOrders   SalesOrder[]
  ledgerEntries PartyLedger[]
  quotations    Quotation[]
  contacts      CustomerContact[]
  receipts      CustomerReceipt[]
  portalUsers   CustomerUser[]
  paymentSlips  PaymentSlip[]
  salesReturns  SalesReturn[]
  openingBalance OpeningBalance?
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  name       String
  whatsapp   String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  location  String
  godown    String?
  manager   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockEntries   StockEntry[]
  purchaseOrders PurchaseOrder[]
  deliveryOrders DeliveryOrder[]
  contacts       WarehouseContact[]
  salesReturns   SalesReturn[]
}

model WarehouseContact {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  name        String
  whatsapp    String
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model Bank {
  id        String   @id @default(cuid())
  name      String
  branch    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  purchaseOrders   PurchaseOrder[]
  customerReceipts CustomerReceipt[]
}

model CostingCalculation {
  id        String @id @default(cuid())
  reference String @unique
  status    String @default("DRAFT")

  fobPerWatt         Float
  freightPerWatt     Float
  exchangeRateId     String?
  exchangeRate       ExchangeRate? @relation(fields: [exchangeRateId], references: [id])
  customExchangeRate Float?
  taxConfigId        String?
  taxConfig          TaxConfig?    @relation(fields: [taxConfigId], references: [id])
  customTaxRate      Float?
  panelWattage       Int
  totalPanels        Int
  notes              String?

  cifPerWattUsd      Float
  effectiveExRate    Float
  cifPerWattPkr      Float
  taxRate            Float
  taxPerWatt         Float
  handlingPerWatt    Float
  landedCostPerWatt  Float
  landedCostPerPanel Float
  totalShipmentValue Float

  // Import cost breakdown (Step 02)
  impLcValuePkr       Float?
  impFreightFob       Float?
  impBankCharges      Float?
  impMarineInsurance  Float?
  impSalesTax         Float?
  impExcise           Float?
  impShippingDO       Float?
  impTerminalHandling Float?
  impMiscClearing     Float?
  impTransportation   Float?
  impMiscAdminGs      Float?
  impTotalCost        Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id         String   @id @default(cuid())
  poNumber   String   @unique
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  lcType     LCType
  lcNumber   String?
  usanceDays Int?
  bankId     String?
  bank       Bank?    @relation(fields: [bankId], references: [id])

  leadTimeDays   Int?
  warehouseId    String?
  warehouse      Warehouse? @relation(fields: [warehouseId], references: [id])
  noOfContainers Int?
  noOfPallets    Int?
  noOfPanels     Int
  panelWattage   Int
  totalWatts     Int
  usdPerWatt     Float
  totalValueUsd  Float
  exchangeRateId String?
  exchangeRate   ExchangeRate? @relation(fields: [exchangeRateId], references: [id])
  poAmountPkr    Float

  costingId String?
  costing   CostingCalculation? @relation(fields: [costingId], references: [id])

  status String  @default("DRAFT")
  notes  String?

  lcValuePkr            Float?
  importFreightCost     Float?
  importShippingFreight Float?
  bankCharges           Float?
  marineInsurance       Float?
  exciseCharges         Float?
  shippingDO            Float?
  terminalHandling      Float?
  clearingCharges       Float?
  miscClearing          Float?
  containerTransport    Float?
  gstInputAmount        Float?
  totalLandedCost       Float?
  landedCostPerPanel    Float?
  landedCostPerWatt     Float?
  clearingExchangeRate  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents      PODocument[]
  stockMovements StockMovement[]
  stockEntries   StockEntry[]
}

model PODocument {
  id          String        @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id])
  docType     String
  fileName    String
  fileUrl     String
  uploadedAt  DateTime      @default(now())
  uploadedBy  String
}

model StockEntry {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  poId        String?
  po          PurchaseOrder? @relation(fields: [poId], references: [id])
  lcReference String?

  panelQuantity Int
  wattQuantity  Int
  costPerPanel  Float
  costPerWatt   Float
  totalValue    Float

  // origin = PURCHASE (received against a PO) or ADJUSTMENT (found-stock increase,
  // a self-standing cost layer at an admin-entered cost, poId null).
  origin             String  @default("PURCHASE")
  adjustmentCategory String?
  adjustmentReason   String?

  receivedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  movements StockMovement[]
  returnLines SalesReturnLine[]
}

model StockMovement {
  id           String            @id @default(cuid())
  stockEntryId String?
  stockEntry   StockEntry?       @relation(fields: [stockEntryId], references: [id])
  type         StockMovementType
  quantity     Int
  watts        Int
  poId         String?
  po           PurchaseOrder?    @relation(fields: [poId], references: [id])
  soId         String?
  salesOrder   SalesOrder?       @relation(fields: [soId], references: [id])
  doId         String?
  deliveryOrder DeliveryOrder?   @relation(fields: [doId], references: [id])
  returnId     String?
  salesReturn  SalesReturn?      @relation(fields: [returnId], references: [id])
  // Cost snapshot + classification for manual DECREASE adjustments (write-offs).
  unitCost     Float?
  category     String?
  reason       String?
  approvedBy   String?
  userId       String?
  user         User?             @relation(fields: [userId], references: [id])
  createdAt    DateTime          @default(now())
}

model Quotation {
  id         String    @id @default(cuid())
  qNumber    String    @unique
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id])
  validUntil DateTime?
  notes      String?
  status     String    @default("DRAFT")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  lines       QuotationLine[]
  salesOrders SalesOrder[]
}

model QuotationLine {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int
  watts       Int
  ratePerWatt Float
  ratePerPanel Float
  totalAmount Float
}

model SalesOrder {
  id           String           @id @default(cuid())
  soNumber     String           @unique
  quotationId  String?
  quotation    Quotation?       @relation(fields: [quotationId], references: [id])
  customerId   String
  customer     Customer         @relation(fields: [customerId], references: [id])
  customerType CustomerType     @default(DIRECT)
  paymentTerms PaymentTerms     @default(FULL_PAYMENT)
  status       SalesOrderStatus @default(DRAFT)

  gstRate   Float @default(0)
  subTotal  Float
  gstAmount Float
  grandTotal Float

  paymentProofUrl   String?
  paymentVerifiedAt DateTime?
  paymentVerifiedBy String?

  notes       String?
  orderDate   DateTime @default(now())
  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Balance closure — the undelivered/uncommitted panels an admin has written off
  // (kept on record). Subtracted from the SO's remaining-to-deliver quantity.
  balanceCancelledQty    Int       @default(0)
  balanceCancelledAt     DateTime?
  balanceCancelledBy     String?
  balanceCancelReason    String?

  lines          SalesOrderLine[]
  deliveryOrders DeliveryOrder[]
  stockMovements StockMovement[]
  invoices       Invoice[]
  ledgerEntries  PartyLedger[]
  salesReturns   SalesReturn[]
}

model SalesOrderLine {
  id           String     @id @default(cuid())
  soId         String
  salesOrder   SalesOrder @relation(fields: [soId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Int
  watts        Int
  ratePerWatt  Float
  ratePerPanel Float
  totalAmount  Float
  stockEntryId String?

  deliveryLines DeliveryOrderLine[]
  returnLines   SalesReturnLine[]
}

model DeliveryOrder {
  id          String     @id @default(cuid())
  doNumber    String     @unique
  referenceNo String?    // Customer's own DO number (from their Excel sheet)
  soId        String
  salesOrder  SalesOrder @relation(fields: [soId], references: [id])
  warehouseId String
  warehouse   Warehouse  @relation(fields: [warehouseId], references: [id])

  quantity Int
  watts    Int

  status       String    @default("PENDING")
  authorizedBy String?
  authorizedAt DateTime?
  dispatchedAt DateTime?

  createdById  String?
  createdBy    User?   @relation(fields: [createdById], references: [id])
  notes        String?
  validityDays Int     @default(3)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lines          DeliveryOrderLine[]
  stockMovements StockMovement[]
  invoices       Invoice[]
  salesReturns   SalesReturn[]
}

model DeliveryOrderLine {
  id            String        @id @default(cuid())
  doId          String
  deliveryOrder DeliveryOrder @relation(fields: [doId], references: [id], onDelete: Cascade)
  soLineId      String?
  salesOrderLine SalesOrderLine? @relation(fields: [soLineId], references: [id], onDelete: SetNull)
  productId     String
  product       Product       @relation(fields: [productId], references: [id])
  quantity      Int
  watts         Int
  createdAt     DateTime      @default(now())
}

enum SalesReturnType {
  RETURN
  EXCHANGE
}

enum SalesReturnStatus {
  COMPLETED
  VOID
}

// A customer return / exchange of goods that were already dispatched on a DO.
// Puts stock back onto the original cost layers (via positive ADJUSTMENT
// movements) and issues a credit note that computeLedger reads as a credit.
// Money stays SO-driven: an EXCHANGE's replacement value flows through an SO edit.
model SalesReturn {
  id           String            @id @default(cuid())
  returnNumber String            @unique
  type         SalesReturnType   @default(RETURN)
  status       SalesReturnStatus @default(COMPLETED)

  doId          String
  deliveryOrder DeliveryOrder @relation(fields: [doId], references: [id])
  soId          String
  salesOrder    SalesOrder    @relation(fields: [soId], references: [id])
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  warehouseId   String
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id])

  creditAmount Float  @default(0)
  reason       String?
  notes        String?
  returnDate   DateTime @default(now())

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])
  voidedAt    DateTime?
  voidedById  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines          SalesReturnLine[]
  stockMovements StockMovement[]

  @@index([customerId])
  @@index([doId])
}

model SalesReturnLine {
  id          String      @id @default(cuid())
  returnId    String
  salesReturn SalesReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productId   String
  product     Product     @relation(fields: [productId], references: [id])
  // Original cost layer the goods return to (the StockEntry the DO's STOCK_OUT drew from).
  stockEntryId String?
  stockEntry   StockEntry? @relation(fields: [stockEntryId], references: [id])
  soLineId    String?
  salesOrderLine SalesOrderLine? @relation(fields: [soLineId], references: [id], onDelete: SetNull)

  quantity    Int
  watts       Int
  ratePerWatt Float  @default(0) // editable; defaults to the matched SO line rate
  amount      Float  @default(0) // credit value for this line
  createdAt   DateTime @default(now())
}

model Invoice {
  id            String  @id @default(cuid())
  invoiceNumber String  @unique
  soId          String
  salesOrder    SalesOrder @relation(fields: [soId], references: [id])
  doId          String?
  deliveryOrder DeliveryOrder? @relation(fields: [doId], references: [id])

  customerId  String
  invoiceDate DateTime @default(now())

  subTotal   Float
  gstRate    Float
  gstAmount  Float
  grandTotal Float

  status    String   @default("UNPAID")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments      Payment[]
  ledgerEntries PartyLedger[]
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  amount      Float
  paymentDate DateTime
  method      String?
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())
}

model PartyLedger {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  date        DateTime
  description String
  debit       Float    @default(0)
  credit      Float    @default(0)
  balance     Float
  invoiceId   String?
  invoice     Invoice?    @relation(fields: [invoiceId], references: [id])
  soId        String?
  salesOrder  SalesOrder? @relation(fields: [soId], references: [id])
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  changes   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model Counter {
  id    String @id
  value Int    @default(0)
}

model Expense {
  id           String          @id @default(cuid())
  date         DateTime
  category     ExpenseCategory
  categoryName String?
  description  String
  amount       Float
  paidTo       String?
  reference    String?
  notes        String?
  createdById  String?
  createdBy    User?           @relation(fields: [createdById], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model ExpenseCategoryDef {
  id        String   @id @default(cuid())
  name      String   @unique
  isSystem  Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum OpeningDirection {
  RECEIVABLE // party owed us money before we started tracking (opening debit)
  ADVANCE    // party had paid ahead / we owed them (opening credit)
}

// A party's opening balance as of a cut-off date. One per party. Seeds the
// derived ledger with a starting figure so pre-system history is reflected
// without back-filling every old SO/collection. Consumed by computeLedger
// (a synthetic OPENING row) and the /balance aggregate route.
model OpeningBalance {
  id          String           @id @default(cuid())
  customerId  String           @unique
  customer    Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  date        DateTime         // "as of" date
  amount      Float            // always positive PKR
  direction   OpeningDirection
  notes       String?
  createdById String?
  createdBy   User?            @relation(fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model CustomerReceipt {
  id           String    @id @default(cuid())
  receiptNo    String    @unique
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])
  bankId       String
  bank         Bank      @relation(fields: [bankId], references: [id])
  amount       Float
  reference    String?
  referenceKey String?   // normalized reference (trim/collapse-space/upper) for duplicate lookups; non-unique
  valueDate    DateTime
  whatsappDate DateTime?
  notes        String?
  createdById  String?
  createdBy    User?     @relation(fields: [createdById], references: [id])
  slip         PaymentSlip?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([bankId, referenceKey])
}

enum PaymentSlipStatus {
  PENDING
  VERIFIED
  REJECTED
  ALREADY_RECEIVED
}

// A portal login for a customer/party. Many logins may belong to one Customer.
model CustomerUser {
  id          String    @id @default(cuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  email       String    @unique
  password    String
  name        String
  active      Boolean   @default(true)
  lastLoginAt DateTime?
  createdById String?   // staff User who provisioned the login
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  slips       PaymentSlip[]

  @@index([customerId])
}

// A payment slip submitted by a party (or staff). Reviewed -> becomes a CustomerReceipt.
model PaymentSlip {
  id               String            @id @default(cuid())
  customerId       String
  customer         Customer          @relation(fields: [customerId], references: [id])
  submittedById    String?           // CustomerUser who uploaded; null if staff-uploaded
  submittedBy      CustomerUser?     @relation(fields: [submittedById], references: [id])
  imageUrl         String?           // Vercel Blob URL (server-side only); nulled after retention purge
  fileType         String
  imagePurgedAt    DateTime?         // set when the blob image is auto-deleted
  status           PaymentSlipStatus @default(PENDING)
  // party-submitted values — the minimal form is only amount + date + image
  claimedAmount    Float?
  claimedValueDate DateTime?
  // review outcome (staff)
  reviewedById     String?
  reviewedAt       DateTime?
  rejectionReason  String?
  linkedReceiptId  String?           @unique
  linkedReceipt    CustomerReceipt?  @relation(fields: [linkedReceiptId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status])
  @@index([customerId])
}
